# =============================================================================
# Form2Sign - Dockerfile for Development
# =============================================================================
# Ce Dockerfile est utilise pour le developpement avec auto-reload (nodemon)
# Ne pas utiliser en production
# =============================================================================

FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including devDependencies)
RUN npm install

# Copy all source files
COPY . .

# Expose port
EXPOSE 3000

# Start the application with nodemon
CMD ["npm", "run", "dev"]
