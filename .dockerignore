# =============================================================================
# Form2Sign - Docker Ignore File
# Files and directories that should not be copied into the Docker image
# =============================================================================

# Git
.git
.git/

# Node.js
node_modules/
npm-debug.log*

# Environment files (contain secrets)
.env
.env.*
!.env.example

# Documentation (optional - uncomment if you want to exclude docs)
# README.md
# DEV_LOG.md

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Build artifacts
dist/
build/

# Docker files (these are already used by Docker)
Dockerfile
docker-compose.yml
.dockerignore

# Uploads (persistent data - mounted as volumes)
backend/uploads/

# Temporary files
tmp/
temp/

# Test files (optional - uncomment if you want to exclude tests)
# tests/
# __tests__/
# *.test.js
# *.spec.js
