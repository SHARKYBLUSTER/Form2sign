# =============================================================================
# Form2Sign - Configuration Environment Variables
# =============================================================================
# Copiez ce fichier vers .env et adaptez les valeurs
# N'oubliez pas d'ajouter .env a votre .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# AUTHENTIFICATION
# -----------------------------------------------------------------------------
# Nom d'utilisateur pour la connexion
APP_USER=admin

# Mot de passe pour la connexion (sera hashe automatiquement au premier demarrage)
APP_PASSWORD=changeme

# Cle secrete pour les cookies de session
# Genere une cle aleatoire : openssl rand -base64 32
SESSION_SECRET=your_super_secret_random_key_here_change_me_please

# -----------------------------------------------------------------------------
# SERVEUR
# -----------------------------------------------------------------------------
# Port sur lequel l'application ecoute
PORT=3000

# Environnement (development ou production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# STOCKAGE
# -----------------------------------------------------------------------------
# Chemin de stockage des PDFs generes
PDF_STORAGE_PATH=./backend/uploads/pdfs

# Repertoire des formulaires YAML
FORMS_DIRECTORY=./backend/forms

# -----------------------------------------------------------------------------
# SESSION
# -----------------------------------------------------------------------------
# Duree de vie des cookies de session (en millisecondes)
# 24 heures = 86400000
SESSION_MAX_AGE=86400000

# Nom du cookie de session
SESSION_NAME=form2sign_sid

# -----------------------------------------------------------------------------
# SECURITE
# -----------------------------------------------------------------------------
# Active le HTTPS (requiert des certificats SSL)
HTTPS_ENABLED=false

# Chemin vers les certificats SSL (si HTTPS_ENABLED=true)
# SSL_CERT_PATH=./config/ssl/cert.pem
# SSL_KEY_PATH=./config/ssl/key.pem

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Origines autorisees (separees par des virgules)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Active les credentials (cookies) dans CORS
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Niveau de log (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info
