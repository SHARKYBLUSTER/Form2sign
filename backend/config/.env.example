# =============================================================================
# Form2Sign - Configuration Environment Variables
# =============================================================================
# Copiez ce fichier vers .env et adaptez les valeurs
# N'oubliez pas d'ajouter .env a votre .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# AUTHENTIFICATION
# -----------------------------------------------------------------------------
# Nom d'utilisateur pour la connexion
APP_USER=admin

# Mot de passe pour la connexion (sera hashe automatiquement au premier demarrage)
APP_PASSWORD=changeme

# Cle secrete pour les cookies de session
# IMPORTANT: Genere une cle aleatoire UNIQUE avec: openssl rand -base64 32
# Ne JAMAIS utiliser cette valeur par defaut en production !
SESSION_SECRET=change_me_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# SERVEUR
# -----------------------------------------------------------------------------
# Port sur lequel l'application ecoute
PORT=3000

# Environnement (development ou production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# STOCKAGE
# -----------------------------------------------------------------------------
# Chemin de stockage des PDFs generes (relatif au repertoire backend/)
PDF_STORAGE_PATH=./uploads/pdfs

# Repertoire des formulaires YAML (relatif au repertoire backend/)
FORMS_DIRECTORY=./forms

# -----------------------------------------------------------------------------
# SESSION
# -----------------------------------------------------------------------------
# Duree de vie des cookies de session (en millisecondes)
# 24 heures = 86400000
SESSION_MAX_AGE=86400000

# Nom du cookie de session
SESSION_NAME=form2sign_sid

# -----------------------------------------------------------------------------
# SECURITE
# -----------------------------------------------------------------------------
# Active le HTTPS (requiert des certificats SSL)
HTTPS_ENABLED=false

# Chemin vers les certificats SSL (si HTTPS_ENABLED=true)
# SSL_CERT_PATH=./config/ssl/cert.pem
# SSL_KEY_PATH=./config/ssl/key.pem

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Origines autorisees (separees par des virgules)
# Exemples: http://localhost:3000, http://ton-ip-vps:3000, https://ton-domaine.com
# Pour production sur VPS: utilisez l'IP ou le domaine de votre serveur
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://51.68.124.77:3000

# Active les credentials (cookies) dans CORS (requis pour l'authentification)
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Niveau de log (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# CONFIGURATION PDF (optionnel)
# -----------------------------------------------------------------------------
# Ces options permettent de personnaliser les PDF generes
# Elles peuvent etre definies ici (globales) ou dans chaque formulaire YAML

# Titre du PDF (peut inclure des variables comme {full_name}, {date}, {time})
PDF_TITLE="Formulaire signé - {full_name}"

# Texte à afficher en footer du PDF
PDF_FOOTER="Document signé électroniquement via Form2Sign"

# Inclure un timestamp automatique (true/false)
PDF_INCLUDE_TIMESTAMP=true

# Taille de page: A4, A5, Letter, etc.
PDF_PAGE_SIZE=A4

# Orientation: portrait ou landscape
PDF_ORIENTATION=portrait
